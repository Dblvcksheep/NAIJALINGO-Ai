:root {
  --bg: #f5f7fb;
  --surface: rgba(255,255,255,0.9);
  --surface-2: #f8fafc;
  --text: #0f172a;
  --muted: #64748b;
  --border: rgba(148, 163, 184, 0.24);
  --accent: #111827;
  --accent-soft: #eef2ff;
  --shadow: 0 18px 40px rgba(15, 23, 42, 0.06);
}

* {
  box-sizing: border-box;
}

body {
  margin: 0;
  font-family: Inter, "Segoe UI", Roboto, Arial, sans-serif;
  color: var(--text);
  background: radial-gradient(circle at top left, rgba(99, 102, 241, 0.13), transparent 24%), linear-gradient(135deg, #f8fafc 0%, var(--bg) 100%);
}

a {
  color: inherit;
  text-decoration: none;
}

button,
input,
select,
textarea {
  font: inherit;
}

.app-shell {
  display: flex;
  min-height: 100vh;
}

.sidebar {
  width: 280px;
  background: rgba(255,255,255,0.72);
  border-right: 1px solid var(--border);
  padding: 24px 20px;
  position: sticky;
  top: 0;
  height: 100vh;
  display: flex;
  flex-direction: column;
  gap: 20px;
  backdrop-filter: blur(24px);
}

.brand {
  display: flex;
  align-items: center;
  gap: 12px;
  padding-bottom: 18px;
  border-bottom: 1px solid var(--border);
}

.brand-mark {
  width: 44px;
  height: 44px;
  display: grid;
  place-items: center;
  border-radius: 14px;
  background: linear-gradient(135deg, var(--accent), #374151);
  color: white;
  font-weight: 700;
  box-shadow: var(--shadow);
}

.brand h1 {
  margin: 0;
  font-size: 1rem;
}

.brand p {
  margin: 4px 0 0;
  color: var(--muted);
  font-size: 0.9rem;
}

.sidebar nav {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.sidebar nav a {
  padding: 10px 12px;
  border-radius: 12px;
  color: var(--muted);
  transition: all 0.2s ease;
}

.sidebar nav a:hover,
.sidebar nav a.active {
  background: linear-gradient(135deg, rgba(99,102,241,0.12), rgba(148,163,184,0.12));
  color: var(--accent);
  font-weight: 600;
  transform: translateX(2px);
}

.nav-divider {
  height: 1px;
  background: var(--border);
  margin: 10px 0;
}

.mobile-toggle {
  display: none;
  position: fixed;
  top: 16px;
  left: 16px;
  z-index: 40;
  border: 0;
  border-radius: 999px;
  background: linear-gradient(135deg, var(--accent), #374151);
  color: white;
  width: 48px;
  height: 48px;
  box-shadow: var(--shadow);
  padding: 0;
  align-items: center;
  justify-content: center;
  gap: 4px;
  flex-direction: column;
}

.mobile-toggle span {
  display: block;
  width: 18px;
  height: 2px;
  background: white;
  border-radius: 999px;
  transition: transform 0.2s ease, opacity 0.2s ease;
}

.nav-overlay {
  display: none;
}

.content {
  flex: 1;
  padding: 28px 32px 40px;
}

.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16px;
  margin-bottom: 20px;
}

.page-header h2 {
  margin: 4px 0 0;
  font-size: 1.6rem;
}

.header-pill {
  padding: 10px 14px;
  border-radius: 999px;
  background: var(--surface);
  color: var(--muted);
  border: 1px solid var(--border);
  box-shadow: var(--shadow);
}

.hero-panel {
  display: grid;
  grid-template-columns: 1.35fr 0.95fr;
  gap: 20px;
  margin-bottom: 20px;
}

.hero-copy,
.info-card,
.card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 24px;
  box-shadow: var(--shadow);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.hero-copy:hover,
.info-card:hover,
.card:hover {
  transform: translateY(-2px);
  box-shadow: 0 24px 48px rgba(15, 23, 42, 0.08);
}

.hero-copy {
  padding: 30px;
}

.hero-copy h1 {
  font-size: clamp(1.8rem, 3vw, 2.6rem);
  margin: 0 0 12px;
  line-height: 1.08;
}

.hero-copy p {
  color: var(--muted);
  line-height: 1.65;
}

.eyebrow {
  text-transform: uppercase;
  letter-spacing: 0.2em;
  font-size: 0.74rem;
  font-weight: 700;
  color: #6366f1;
  margin-bottom: 8px;
}

.actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-top: 18px;
}

.button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10px 16px;
  border: 1px solid var(--border);
  border-radius: 999px;
  background: var(--surface-2);
  color: var(--text);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.button:hover {
  transform: translateY(-1px);
  box-shadow: var(--shadow);
}

.button.primary {
  background: linear-gradient(135deg, #111827, #374151);
  color: white;
  border-color: transparent;
}

.card {
  padding: 20px;
  margin-bottom: 18px;
}

.info-card {
  padding: 24px;
}

.status-badge {
  display: inline-block;
  padding: 7px 10px;
  border-radius: 999px;
  background: var(--accent-soft);
  color: #4338ca;
  font-weight: 700;
  font-size: 0.8rem;
  margin-bottom: 10px;
}

.grid {
  display: grid;
  gap: 16px;
}

.grid.two {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.grid.three {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.metric {
  padding: 18px;
  border-radius: 18px;
  background: linear-gradient(135deg, rgba(248,250,252,0.95), rgba(241,245,249,0.75));
  border: 1px solid var(--border);
}

.metric strong {
  display: block;
  font-size: 1.3rem;
  margin-top: 4px;
}

input,
select,
textarea {
  width: 100%;
  padding: 11px 12px;
  margin: 8px 0 12px;
  border: 1px solid var(--border);
  border-radius: 12px;
  background: rgba(248,250,252,0.95);
}

input:focus,
select:focus,
textarea:focus {
  outline: 2px solid rgba(99, 102, 241, 0.25);
  border-color: #818cf8;
}

.auth-card {
  max-width: 520px;
}

.review-item {
  border-top: 1px solid var(--border);
  padding-top: 16px;
  margin-top: 16px;
}

ul {
  padding-left: 18px;
  color: var(--muted);
}

.spotlight {
  background: linear-gradient(135deg, rgba(248,250,252,0.95), rgba(238,242,255,0.7));
}

@media (max-width: 900px) {
  .mobile-toggle {
    display: inline-flex;
  }

  .nav-overlay {
    display: block;
    position: fixed;
    inset: 0;
    background: rgba(2, 6, 23, 0.45);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
    z-index: 15;
  }

  .nav-overlay.visible {
    opacity: 1;
    pointer-events: auto;
  }

  .app-shell {
    flex-direction: column;
  }

  .sidebar {
    width: min(82vw, 320px);
    height: 100vh;
    position: fixed;
    left: -100%;
    top: 0;
    bottom: 0;
    z-index: 20;
    transition: left 0.25s ease;
    padding-top: 28px;
    border-right: 1px solid var(--border);
  }

  body.nav-open .sidebar {
    left: 0;
  }

  .content {
    padding: 76px 18px 28px;
  }

  .hero-panel,
  .grid.two,
  .grid.three {
    grid-template-columns: 1fr;
  }

  .page-header {
    align-items: start;
    flex-direction: column;
  }
}
